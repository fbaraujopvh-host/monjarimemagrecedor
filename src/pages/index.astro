---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import VSL from '../components/VSL.astro';
import Depoimentos from '../components/Depoimentos.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Leveza — Emagreça sem dieta restritiva nem academia">
  <Header />
  <main>
    <Hero />
    <VSL delaySeconds={180} />
    <Depoimentos />

    <section id="oferta" class="px-4 sm:px-8 py-10 max-w-2xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">Garanta sua vaga agora</h2>
      <p class="text-white/70 mb-6">
        Acesso completo ao método com acompanhamento e bônus exclusivos para quem entrar hoje.
      </p>
      <a
        href="#"
        class="inline-block w-full sm:w-auto bg-brand-500 hover:bg-brand-600 text-white font-extrabold text-base sm:text-lg px-10 py-4 rounded-xl transition"
      >
        Quero minha vaga →
      </a>
    </section>
  </main>
  <Footer />
</Layout>
