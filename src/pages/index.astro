---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import VSL from '../components/VSL.astro';
import Depoimentos from '../components/Depoimentos.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Leveza — Emagreça sem dieta restritiva nem academia">
  <TopBar />
  <Header />
  <main>
    <Hero />
    <VSL delaySeconds={180} />

    <p class="px-4 sm:px-8 py-6 max-w-3xl mx-auto text-center text-sm sm:text-base font-bold" style="color: #c9116b;">
      Importante: o Monjarim NÃO está disponível em farmácias.
    </p>

    <Depoimentos />

    <section id="oferta" class="px-4 sm:px-8 py-10 max-w-3xl mx-auto text-center">
      <h2 class="text-xl sm:text-2xl font-bold mb-3">Quero garantir o meu Monjarim agora</h2>
      <p class="text-sm sm:text-base text-white/70 mb-6">
        Clique no botão abaixo, e garanta agora mesmo o seu Monjarim.
      </p>
      <a
        href="#"
        class="inline-block w-full sm:w-auto text-white font-extrabold uppercase text-xs sm:text-sm px-8 py-3 rounded-full transition hover:opacity-90"
        style="background-color: #c9116b;"
      >
        Garantir agora!
      </a>
    </section>
  </main>
  <Footer />
</Layout>
