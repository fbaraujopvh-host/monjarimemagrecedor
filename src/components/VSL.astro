---
export interface Props {
  youtubeId?: string;
  delaySeconds?: number;
}

const {
  youtubeId = 'A7ja3QH-HgU',
  delaySeconds = 180,
} = Astro.props;

const embedSrc = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&mute=1&controls=0&modestbranding=1&rel=0&disablekb=1&playsinline=1&enablejsapi=1`;
---

<section class="px-4 sm:px-8 py-6 max-w-4xl mx-auto" id="vsl-section">
  <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50 border border-white/10 bg-ink-800">
    <span class="absolute top-3 left-3 z-10 flex items-center gap-2 bg-black/60 text-xs font-semibold px-2.5 py-1 rounded-full">
      <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
      EM TRANSMISSÃO
    </span>

    <iframe
      id="vsl-video"
      class="live-video w-full aspect-video bg-black"
      src={embedSrc}
      title="Vídeo"
      frameborder="0"
      allow="autoplay; encrypted-media"
      allowfullscreen={false}
      oncontextmenu="return false;"
    >
    </iframe>

    <button
      id="vsl-unmute"
      class="absolute bottom-3 right-3 z-10 bg-white/10 hover:bg-white/20 backdrop-blur text-xs font-semibold px-3 py-2 rounded-lg transition"
      type="button"
    >
      🔊 Ativar som
    </button>
  </div>

  <p class="text-center text-white/50 text-xs mt-3">
    Mantenha o vídeo aberto. As informações mais importantes aparecem ao longo da transmissão.
  </p>

  <div id="cta-reveal" class="reveal-on-delay mt-6 text-center">
    <p class="text-lg sm:text-xl font-semibold mb-4">
      Chegou a sua hora de transformar o corpo e a autoestima.
    </p>
    <a
      href="https://monjarimro.com.br/monjarim"
      id="cta-button"
      class="inline-block w-full sm:w-auto bg-brand-500 hover:bg-brand-600 text-white font-extrabold text-base sm:text-lg px-8 py-4 rounded-xl animate-pulseGlow transition"
    >
      Quero emagrecer agora →
    </a>
    <p class="text-white/50 text-xs mt-3">Vagas limitadas para a turma de hoje</p>
  </div>
</section>

<script define:vars={{ delaySeconds }}>
  const video = document.getElementById('vsl-video');
  const unmuteBtn = document.getElementById('vsl-unmute');
  const ctaReveal = document.getElementById('cta-reveal');

  let muted = true;

  function sendYouTubeCommand(func) {
    video?.contentWindow?.postMessage(
      JSON.stringify({ event: 'command', func, args: [] }),
      '*'
    );
  }

  unmuteBtn?.addEventListener('click', () => {
    muted = !muted;
    sendYouTubeCommand(muted ? 'mute' : 'unMute');
    unmuteBtn.textContent = muted ? '🔊 Ativar som' : '🔇 Silenciar';
  });

  function revealCta() {
    ctaReveal?.classList.add('is-visible');
  }

  // Revela o CTA e os blocos de "pitch" após X segundos de vídeo assistido
  let revealed = false;

  setTimeout(() => {
    if (!revealed) {
      revealed = true;
      revealCta();
    }
  }, delaySeconds * 1000);
</script>
