---
const depoimentos = [
  {
    nome: 'Patrícia M.',
    resultado: '-16,8kg (93,3kg → 76,5kg)',
    foto: '/img/depoimento-1.jpeg',
    texto: '"Eu já tinha tentado de tudo. Com o Monjarim consegui perder quase 17kg sem passar fome. Hoje me olho no espelho e sinto orgulho."',
  },
  {
    nome: 'Carlos R.',
    resultado: '-15,5kg (97,5kg → 82kg)',
    foto: '/img/depoimento-2.jpeg',
    texto: '"O método é simples e cabe na minha rotina. Em poucos meses já vi a diferença no corpo, na roupa e na energia do dia a dia."',
  },
  {
    nome: 'Thamires',
    resultado: '-23kg',
    foto: '/img/depoimento-3.jpeg',
    texto: '"Comecei sem fé, achando que era igual aos outros. Hoje recuperei minha autoestima e minha saúde voltou aos exames normais."',
  },
];
---

<section class="px-4 sm:px-8 py-12 max-w-5xl mx-auto" id="depoimentos">
  <h2 class="text-center text-2xl sm:text-3xl font-bold mb-8">
    Quem já está colhendo os resultados
  </h2>

  <div class="grid gap-5 sm:grid-cols-3">
    {depoimentos.map((d) => (
      <article class="bg-ink-800 border border-white/10 rounded-2xl overflow-hidden flex flex-col text-center">
        <img
          src={d.foto}
          alt={`Antes e depois de ${d.nome}`}
          width="400"
          height="400"
          class="w-full aspect-square object-cover"
          loading="lazy"
        />
        <div class="p-5 flex flex-col items-center">
          <p class="text-sm text-white/80 mb-3">{d.texto}</p>
          <span class="text-sm font-semibold">{d.nome}</span>
          <span class="text-xs text-brand-400 font-bold mt-1">{d.resultado}</span>
        </div>
      </article>
    ))}
  </div>
</section>
